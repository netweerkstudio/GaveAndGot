<header class="navbar">
  <div class="navbar-container">
    <a href="/" class="logo">Gave<span>&</span>Got</a>
    
    <nav class="nav-links">
      <a href="#how-it-works">How it Works</a>
      <a href="#features">Features</a>
      <a href="#pricing">Pricing</a>
      <a href="#register">Early Access</a>
    </nav>
    
    <div class="nav-actions">
      <a href="#register" class="login-link">Join Waitlist</a>
      <a href="#" class="cta-button">Try it Free →</a>
    </div>
  </div>
</header>

<style>
  .navbar {
    /* background-color: #ffffff; */
    /* border-bottom: 1px solid rgba(0, 0, 0, 0.05); */
    width: 100%;
    /* Navbar is intentionally NOT sticky as requested */
  }

  .navbar-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.5px;
  }

  .logo span {
    color: #10b981; /* A nice emerald green to complement the primary background */
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
  }

  .nav-links a {
    color: #4b5563;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .login-link {
    color: #4b5563;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .login-link:hover {
    color: var(--color-text);
  }

  .cta-button {
    background-color: var(--color-text);
    color: #ffffff;
    padding: 0.6rem 1.25rem;
    border-radius: 9999px;
    font-size: 0.95rem;
    font-weight: 600;
    transition: background-color 0.2s ease, transform 0.1s ease;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  .cta-button:hover {
    background-color: #374151;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .login-link {
      display: none;
    }
  }
</style>
