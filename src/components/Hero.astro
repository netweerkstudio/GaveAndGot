---
---
<section class="hero">
  <!-- Step 1: Ingredient Picker -->
  <div class="step" id="step-picker">
    <div class="hero-label">🍳 AI-Powered Cooking — no sign up needed</div>
    <h1>Give <span class="highlight">ingredients</span>,<br/>get delicious meals.</h1>
    <p class="hero-sub">Pick up to 5 ingredients you have at home. Our AI instantly generates real recipes, steps, and variations just for you.</p>

    <div class="ingredient-grid" id="ingredient-grid">
      <!-- Populated by JS -->
    </div>

    <div class="selected-bar">
      <div class="selected-chips" id="selected-chips"></div>
      <button class="blend-btn" id="blend-btn" disabled>
        Generate my meals 🍽️
      </button>
    </div>
  </div>

  <!-- Step 2: Blender Animation -->
  <div class="step hidden" id="step-blender">
    <div class="blender-wrap">
      <div class="blender-jar">
        <div class="blender-liquid" id="blender-liquid"></div>
        <div class="blender-bubbles">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
      </div>
      <div class="blender-base"></div>
    </div>
    <p class="blend-text">Analysing your ingredients...</p>
  </div>

  <!-- Step 3: Result -->
  <div class="step hidden" id="step-result">
    <div class="result-badge">🤖 AI Recipe Results</div>
    <h2 class="result-title">Using your ingredients:</h2>
    <div class="result-offerings" id="result-offerings"></div>
    <div class="result-arrow">🍽️ You can make these meals:</div>
    <div class="result-cards" id="result-cards"></div>
    <div class="result-actions">
      <button class="try-again-btn" id="try-again-btn">← Try again</button>
      <a href="#register" class="cta-register">Join the waitlist →</a>
    </div>
  </div>
</section>

<style>
  .hero {
    background: #fff;
    margin: 1rem;
    border-radius: 2rem;
    padding: 4rem 3rem;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
    overflow: hidden;
    position: relative;
  }

  .step { width: 100%; max-width: 760px; text-align: center; }
  .step.hidden { display: none; }

  .hero-label {
    display: inline-block;
    background: var(--color-primary);
    color: #1a6b3c;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  h1 {
    font-size: 3.2rem;
    font-weight: 800;
    color: #111827;
    line-height: 1.15;
    margin: 0 0 1rem;
  }

  .highlight { color: #10b981; }

  .hero-sub {
    font-size: 1.1rem;
    color: #6b7280;
    margin-bottom: 2.5rem;
  }

  /* Ingredient Grid */
  .ingredient-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .ingredient-chip {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1.1rem;
    border-radius: 9999px;
    border: 2px solid #e5e7eb;
    background: #f9fafb;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.18s ease;
    user-select: none;
    color: #374151;
  }

  .ingredient-chip:hover:not(.disabled) {
    border-color: #10b981;
    background: #f0fdf4;
    transform: translateY(-2px);
  }

  .ingredient-chip.selected {
    border-color: #10b981;
    background: #dcfce7;
    color: #065f46;
    font-weight: 600;
  }

  .ingredient-chip.disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* Selected bar */
  .selected-bar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    margin-top: 1.5rem;
  }

  .selected-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    min-height: 36px;
  }

  .sel-chip {
    background: #111827;
    color: #fff;
    padding: 0.35rem 0.9rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600;
    animation: popIn 0.2s ease;
  }

  @keyframes popIn {
    from { transform: scale(0.7); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .blend-btn {
    background: #10b981;
    color: #fff;
    border: none;
    padding: 0.9rem 2.5rem;
    border-radius: 9999px;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: 0.01em;
  }

  .blend-btn:disabled { background: #d1d5db; color: #9ca3af; cursor: not-allowed; transform: none !important; }
  .blend-btn:not(:disabled):hover { background: #059669; transform: translateY(-2px); }

  /* Blender */
  .blender-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
    animation: shake 0.5s ease infinite alternate;
  }

  @keyframes shake {
    from { transform: rotate(-1deg); }
    to { transform: rotate(1deg); }
  }

  .blender-jar {
    width: 120px;
    height: 160px;
    background: rgba(220,239,221,0.5);
    border: 3px solid #10b981;
    border-radius: 8px 8px 20px 20px;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(4px);
  }

  .blender-liquid {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 70%;
    background: linear-gradient(180deg, #6ee7b7, #10b981);
    animation: liquidWave 0.6s ease infinite alternate;
    border-radius: 0 0 16px 16px;
  }

  @keyframes liquidWave {
    from { height: 65%; transform: skewX(-3deg); }
    to { height: 75%; transform: skewX(3deg); }
  }

  .blender-bubbles span {
    position: absolute;
    width: 10px; height: 10px;
    background: rgba(255,255,255,0.7);
    border-radius: 50%;
    bottom: 20%;
    animation: rise 1.2s ease infinite;
  }

  .blender-bubbles span:nth-child(1) { left: 20%; animation-delay: 0s; }
  .blender-bubbles span:nth-child(2) { left: 40%; animation-delay: 0.2s; width:7px; height:7px; }
  .blender-bubbles span:nth-child(3) { left: 60%; animation-delay: 0.4s; }
  .blender-bubbles span:nth-child(4) { left: 30%; animation-delay: 0.6s; width:6px; height:6px; }
  .blender-bubbles span:nth-child(5) { left: 70%; animation-delay: 0.8s; width:8px; height:8px; }

  @keyframes rise {
    from { transform: translateY(0); opacity: 1; }
    to { transform: translateY(-130px); opacity: 0; }
  }

  .blender-base {
    width: 140px; height: 20px;
    background: #111827;
    border-radius: 4px;
    margin-top: -2px;
  }

  .blend-text {
    font-size: 1.2rem;
    color: #374151;
    font-weight: 600;
    animation: pulse 1s ease infinite alternate;
  }

  @keyframes pulse { from { opacity: 0.5; } to { opacity: 1; } }

  /* Result */
  .result-badge {
    display: inline-block;
    background: #dcfce7;
    color: #065f46;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.4rem 1.2rem;
    border-radius: 9999px;
    margin-bottom: 1.2rem;
  }

  .result-title { font-size: 1.8rem; font-weight: 700; margin-bottom: 1rem; color: #111827; }

  .result-offerings {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .result-tag {
    background: #111827;
    color: #fff;
    padding: 0.35rem 0.9rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .result-arrow { font-size: 1rem; color: #6b7280; margin-bottom: 1.5rem; }

  .result-cards {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .result-card {
    background: #f0fdf4;
    border: 2px solid #bbf7d0;
    border-radius: 1rem;
    padding: 1.2rem 1.5rem;
    text-align: left;
    min-width: 160px;
    animation: popIn 0.3s ease both;
  }

  .result-card .rc-emoji { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
  .result-card .rc-name { font-weight: 700; color: #065f46; font-size: 1rem; }
  .result-card .rc-desc { font-size: 0.82rem; color: #6b7280; margin-top: 0.25rem; }

  .result-actions { display: flex; gap: 1rem; justify-content: center; }

  .try-again-btn {
    background: none;
    border: 2px solid #d1d5db;
    color: #374151;
    padding: 0.75rem 1.75rem;
    border-radius: 9999px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .try-again-btn:hover { border-color: #111827; }

  .cta-register {
    background: #10b981;
    color: #fff;
    padding: 0.75rem 1.75rem;
    border-radius: 9999px;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cta-register:hover { background: #059669; transform: translateY(-1px); }

  @media (max-width: 640px) {
    .hero { padding: 3rem 1.5rem; margin: 0.5rem; }
    h1 { font-size: 2.2rem; }
  }
</style>

<script>
  const INGREDIENTS = [
    { emoji: '🥚', label: 'Eggs' },
    { emoji: '🍚', label: 'Rice' },
    { emoji: '🍅', label: 'Tomato' },
    { emoji: '🧀', label: 'Cheese' },
    { emoji: '🍗', label: 'Chicken' },
    { emoji: '🧄', label: 'Garlic' },
    { emoji: '🧅', label: 'Onion' },
    { emoji: '🥦', label: 'Broccoli' },
    { emoji: '🥕', label: 'Carrots' },
    { emoji: '🥔', label: 'Potato' },
    { emoji: '🍝', label: 'Pasta' },
    { emoji: '🐟', label: 'Salmon' },
    { emoji: '🥩', label: 'Beef' },
    { emoji: '🫘', label: 'Beans' },
    { emoji: '🌽', label: 'Corn' },
    { emoji: '🥛', label: 'Milk' },
  ];

  const RESULTS_MAP = [
    { emoji: '🍳', name: 'Scrambled Egg Bowl', desc: '15 min · Easy · High-Protein' },
    { emoji: '🍛', name: 'Tomato Rice Curry', desc: '25 min · Budget-friendly · Veg' },
    { emoji: '🧆', name: 'Cheesy Garlic Bake', desc: '30 min · Comfort food · Easy' },
    { emoji: '🥘', name: 'One-Pan Chicken', desc: '35 min · High-Protein · Quick' },
    { emoji: '🍝', name: 'Pasta Arrabbiata', desc: '20 min · Italian · Vegetarian' },
    { emoji: '🥗', name: 'Roasted Veg Salad', desc: '25 min · Healthy · Low-cal' },
    { emoji: '🍲', name: 'Hearty Bean Stew', desc: '40 min · Vegan · Budget meal' },
    { emoji: '🥞', name: 'Fluffy Pancakes', desc: '15 min · Breakfast · Easy' },
    { emoji: '🍜', name: 'Quick Noodle Soup', desc: '20 min · Comfort · Warming' },
    { emoji: '🫕', name: 'Potato Frittata', desc: '30 min · Italian · Filling' },
  ];

  let selected = [];
  const MAX = 5;

  const grid = document.getElementById('ingredient-grid');
  const chipsEl = document.getElementById('selected-chips');
  const blendBtn = document.getElementById('blend-btn');
  const stepPicker = document.getElementById('step-picker');
  const stepBlender = document.getElementById('step-blender');
  const stepResult = document.getElementById('step-result');

  // Build grid
  INGREDIENTS.forEach((item) => {
    const chip = document.createElement('button');
    chip.className = 'ingredient-chip';
    chip.dataset.label = item.label;
    chip.innerHTML = `${item.emoji} ${item.label}`;
    chip.addEventListener('click', () => toggle(item, chip));
    grid.appendChild(chip);
  });

  function toggle(item, chip) {
    if (chip.classList.contains('selected')) {
      selected = selected.filter(s => s.label !== item.label);
      chip.classList.remove('selected');
    } else {
      if (selected.length >= MAX) return;
      selected.push(item);
      chip.classList.add('selected');
    }
    updateUI();
  }

  function updateUI() {
    // Chips
    chipsEl.innerHTML = selected.map(s => `<span class="sel-chip">${s.emoji} ${s.label}</span>`).join('');
    // Disable unselected when max reached
    document.querySelectorAll('.ingredient-chip').forEach(c => {
      if (!c.classList.contains('selected') && selected.length >= MAX) {
        c.classList.add('disabled');
      } else {
        c.classList.remove('disabled');
      }
    });
    blendBtn.disabled = selected.length === 0;
  }

  blendBtn.addEventListener('click', startBlend);

  function startBlend() {
    stepPicker.classList.add('hidden');
    stepBlender.classList.remove('hidden');

    // Colorise blender liquid based on selection count
    const liquid = document.getElementById('blender-liquid');
    const colors = ['#6ee7b7', '#34d399', '#10b981'];
    liquid.style.background = `linear-gradient(180deg, ${colors[0]}, ${colors[2]})`;

    const messages = ['Analysing your ingredients...', 'Generating AI recipes...', 'Almost ready to cook...'];
    let i = 0;
    const textEl = stepBlender.querySelector('.blend-text');
    const interval = setInterval(() => { textEl.textContent = messages[++i % messages.length]; }, 900);

    setTimeout(() => {
      clearInterval(interval);
      showResult();
    }, 2800);
  }

  function showResult() {
    stepBlender.classList.add('hidden');
    stepResult.classList.remove('hidden');

    // Offerings
    document.getElementById('result-offerings').innerHTML =
      selected.map(s => `<span class="result-tag">${s.emoji} ${s.label}</span>`).join('');

    // Pick 2–3 random results
    const shuffled = [...RESULTS_MAP].sort(() => Math.random() - 0.5).slice(0, Math.min(3, selected.length + 1));
    const cardsEl = document.getElementById('result-cards');
    cardsEl.innerHTML = '';
    shuffled.forEach((r, i) => {
      const card = document.createElement('div');
      card.className = 'result-card';
      card.style.animationDelay = `${i * 0.1}s`;
      card.innerHTML = `<span class="rc-emoji">${r.emoji}</span><div class="rc-name">${r.name}</div><div class="rc-desc">${r.desc}</div>`;
      cardsEl.appendChild(card);
    });
  }

  document.getElementById('try-again-btn').addEventListener('click', () => {
    selected = [];
    document.querySelectorAll('.ingredient-chip').forEach(c => {
      c.classList.remove('selected', 'disabled');
    });
    updateUI();
    stepResult.classList.add('hidden');
    stepPicker.classList.remove('hidden');
  });
</script>
