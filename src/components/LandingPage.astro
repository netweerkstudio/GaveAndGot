---
---

<!-- How it Works -->
<section class="section" id="how-it-works">
  <div class="section-inner">
    <div class="section-badge">How it Works</div>
    <h2 class="section-title">From your fridge to the table<br/>in three steps</h2>
    <p class="section-sub">No recipe browsing. No wasted ingredients. Just smart, AI-powered cooking discovery.</p>
    <div class="steps-grid">
      <div class="step-card">
        <div class="step-icon">🥬</div>
        <h3>Give your ingredients</h3>
        <p>Tell us what you have at home — eggs, rice, chicken, tomato. No need to have everything perfectly stocked.</p>
      </div>
      <div class="step-card">
        <div class="step-icon">🤖</div>
        <h3>AI generates real recipes</h3>
        <p>Our AI instantly matches your ingredients to realistic, delicious meals with full cooking steps and variations.</p>
      </div>
      <div class="step-card">
        <div class="step-icon">🍽️</div>
        <h3>Get meals & cook smarter</h3>
        <p>See prep time, nutrition info, and save your favourites. Reduce food waste and cook creatively every day.</p>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section class="section" id="features">
  <div class="section-inner">
    <div class="section-badge">Features</div>
    <h2 class="section-title">Everything you need to cook smarter</h2>
    <p class="section-sub">Gave&Got isn't just a recipe app — it's your AI-powered cooking companion.</p>
    <div class="features-grid">
      <div class="feature-card">
        <span class="feat-icon">🔍</span>
        <h4>Smart Ingredient Matching</h4>
        <p>Works with whatever you have — no need for exact recipe ingredients.</p>
      </div>
      <div class="feature-card">
        <span class="feat-icon">⚡</span>
        <h4>Instant AI Recipes</h4>
        <p>Get real recipes in seconds, not search results. Tailored to your fridge.</p>
      </div>
      <div class="feature-card">
        <span class="feat-icon">🥗</span>
        <h4>Meal Filters</h4>
        <p>Quick meals, budget-friendly, high-protein, vegetarian — you choose.</p>
      </div>
      <div class="feature-card">
        <span class="feat-icon">🛒</span>
        <h4>Grocery List Generation</h4>
        <p>Missing one ingredient? We'll add it to your shopping list automatically.</p>
      </div>
      <div class="feature-card">
        <span class="feat-icon">❤️</span>
        <h4>Save Favourites</h4>
        <p>Bookmark recipes you love and build your personal cookbook over time.</p>
      </div>
      <div class="feature-card">
        <span class="feat-icon">📊</span>
        <h4>Nutrition Info</h4>
        <p>Optional nutrition details so you can cook with your health goals in mind.</p>
      </div>
    </div>
  </div>
</section>

<!-- AdSense Manual Ad Unit -->
<div class="ad-container" style="text-align: center; margin: 2rem auto; max-width: 1200px; overflow: hidden;">
  <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7850354857239413"
       crossorigin="anonymous"></script>
  <!-- posts-ads -->
  <ins class="adsbygoogle"
       style="display:block"
       data-ad-client="ca-pub-7850354857239413"
       data-ad-slot="9258334883"
       data-ad-format="auto"
       data-full-width-responsive="true"></ins>
  <script is:inline>
       (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>

<!-- Pricing -->
<section class="section section-alt" id="pricing">
  <div class="section-inner">
    <div class="section-badge free-badge">100% Free at Launch</div>
    <h2 class="section-title">Free to cook smarter.</h2>
    <p class="section-sub">Gave&Got launches completely free for early members — no credit card, no catch. Start discovering AI-generated meals today.</p>
    <div class="pricing-cards">
      <div class="pricing-card featured">
        <div class="pricing-label">Early Access</div>
        <div class="pricing-price">Free</div>
        <div class="pricing-desc">For everyone joining at launch</div>
        <ul class="pricing-features">
          <li>✅ Unlimited AI recipe generation</li>
          <li>✅ Smart ingredient matching</li>
          <li>✅ Meal filters (quick, vegan, budget…)</li>
          <li>✅ Save favourite recipes</li>
          <li>✅ Grocery list generation</li>
          <li>✅ Nutrition information</li>
        </ul>
        <a href="#register" class="pricing-cta">Join the waitlist</a>
      </div>
    </div>
    <p class="pricing-note">Premium features may be introduced later — early members keep free access forever.</p>
  </div>
</section>

<!-- Register / Waitlist -->
<section class="section section-register" id="register">
  <div class="section-inner register-inner">
    <h2 class="section-title light">Be first to cook with AI.</h2>
    <p class="section-sub light">Join people in the US, UK, Canada & Australia already on the waitlist. We're launching soon — and it's free.</p>
    <form class="register-form" id="register-form">
      <input type="email" id="email-input" placeholder="your@email.com" required />
      <button type="submit">Get Early Access 🚀</button>
    </form>
    <p class="register-note" id="register-msg"></p>
  </div>
</section>

<style>
  .section {
    padding: 5rem 2rem;
  }

  .section-alt {
    background: #fff;
    margin: 0 1rem;
    border-radius: 2rem;
  }

  .section-register {
    background: #111827;
    margin: 1rem;
    border-radius: 2rem;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .section-badge {
    display: inline-block;
    background: var(--color-primary);
    color: #1a6b3c;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.35rem 1rem;
    border-radius: 9999px;
    margin-bottom: 1.2rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .free-badge {
    background: #dcfce7;
    color: #065f46;
  }

  .section-title {
    font-size: 2.6rem;
    font-weight: 800;
    color: #111827;
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  .section-title.light { color: #fff; }

  .section-sub {
    font-size: 1.05rem;
    color: #6b7280;
    max-width: 560px;
    margin: 0 auto 3rem;
    line-height: 1.7;
  }

  .section-sub.light { color: #d1d5db; }

  /* How it Works Steps */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .step-card {
    background: #fff;
    border: 2px solid #e5e7eb;
    border-radius: 1.25rem;
    padding: 2rem 1.5rem;
    text-align: left;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .step-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0,0,0,0.07);
  }

  .step-icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }

  .step-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 0.5rem;
  }

  .step-card p {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.6;
  }

  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
    text-align: left;
  }

  .feature-card {
    background: #fff;
    border: 2px solid #e5e7eb;
    border-radius: 1.25rem;
    padding: 1.75rem 1.5rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .feature-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 24px rgba(0,0,0,0.07);
  }

  .feat-icon {
    font-size: 1.8rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .feature-card h4 {
    font-size: 1rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.4rem;
  }

  .feature-card p {
    font-size: 0.88rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  /* Pricing */
  .pricing-cards {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .pricing-card {
    background: #111827;
    color: #fff;
    border-radius: 1.5rem;
    padding: 2.5rem 3rem;
    max-width: 380px;
    width: 100%;
    text-align: center;
  }

  .pricing-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #10b981;
    margin-bottom: 0.75rem;
  }

  .pricing-price {
    font-size: 3.5rem;
    font-weight: 900;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  .pricing-desc {
    font-size: 0.9rem;
    color: #9ca3af;
    margin-bottom: 2rem;
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pricing-features li {
    font-size: 0.95rem;
    color: #d1d5db;
  }

  .pricing-cta {
    display: inline-block;
    background: #10b981;
    color: #fff;
    padding: 0.85rem 2rem;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .pricing-cta:hover { background: #059669; }

  .pricing-note {
    font-size: 0.85rem;
    color: #9ca3af;
    margin-top: 1.5rem;
  }

  /* Register */
  .register-inner { padding: 1rem 0; }

  .register-form {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .register-form input {
    padding: 0.85rem 1.5rem;
    border-radius: 9999px;
    border: none;
    background: #1f2937;
    color: #fff;
    font-size: 1rem;
    outline: none;
    min-width: 260px;
    transition: background 0.2s ease;
  }

  .register-form input::placeholder { color: #6b7280; }
  .register-form input:focus { background: #374151; }

  .register-form button {
    padding: 0.85rem 2rem;
    border-radius: 9999px;
    background: #10b981;
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.1s ease;
  }

  .register-form button:hover { background: #059669; transform: translateY(-1px); }

  .register-note {
    font-size: 0.9rem;
    color: #6ee7b7;
    min-height: 1.5rem;
  }

  @media (max-width: 640px) {
    .section-title { font-size: 2rem; }
    .section-alt, .section-register { margin: 0.5rem; }
    .pricing-card { padding: 2rem 1.5rem; }
    .register-form input { min-width: 100%; }
  }
</style>

<script>
  const form = document.getElementById('register-form');
  const msg = document.getElementById('register-msg');

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = document.getElementById('email-input').value;
    msg.textContent = `🎉 You're on the list! We'll reach out to ${email} soon.`;
    form.reset();
  });
</script>
